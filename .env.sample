# Broker
BROKER_PORT=8443
BROKER_HOST=0.0.0.0
BROKER_TLS_CERT=./infra/tls/broker.crt
BROKER_TLS_KEY=./infra/tls/broker.key

# Redis
REDIS_URL=redis://localhost:6379

# NIE bindings mode (public repo defaults to mock; production uses prod via workspace override)
NIE_BINDINGS_MODE=mock

# FHE gate mode
FHE_GATE_MODE=mock

# OpenClaw adapter
OPENCLAW_MODE=mock
OPENCLAW_URL=http://localhost:18789

# Providence
PROVIDENCE_DATA_DIR=./data/providence
PROVIDENCE_ANCHOR_INTERVAL_SECONDS=3600

# Policy bundle
POLICY_BUNDLE_PATH=./infra/policy/default-bundle.json
POLICY_BUNDLE_SIGNER_KEY_ID=mock-key-1

# Logging
LOG_LEVEL=info
